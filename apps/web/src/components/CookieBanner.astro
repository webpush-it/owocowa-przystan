<div id="cookie-banner" class="fixed bottom-6 left-6 right-6 md:left-auto md:max-w-md bg-white border border-stone-200 shadow-2xl rounded-2xl p-6 z-[9999] hidden translate-y-10 opacity-0 transition-all duration-500">
    <div class="flex items-start gap-4">
        <span class="text-2xl">🍎</span>
        <div>
            <h3 class="font-bold text-stone-800 text-lg mb-2">Dbamy o Twoją prywatność</h3>
            <p class="text-stone-600 text-sm leading-relaxed mb-4">
                Używamy ciasteczek, aby zrozumieć, jak korzystasz z naszej strony i móc ją ulepszać. Czy zgadzasz się na analitykę Google?
                <a href="/polityka-prywatnosci" class="text-green-700 hover:text-green-900 transition font-bold no-underline">Szczegóły w polityce</a>.
            </p>
            <div class="flex gap-3">
                <button id="accept-cookies" class="bg-green-700 text-white px-5 py-2 rounded-lg font-bold text-sm hover:bg-green-900 transition-colors">
                    Akceptuję
                </button>
                <button id="reject-cookies" class="bg-stone-100 text-stone-600 px-5 py-2 rounded-lg font-bold text-sm hover:bg-stone-200 transition-colors">
                    Odrzucam
                </button>
            </div>
        </div>
    </div>
</div>

<script is:inline>
    const banner = document.getElementById('cookie-banner');
    const acceptBtn = document.getElementById('accept-cookies');
    const rejectBtn = document.getElementById('reject-cookies');

    // Funkcja aktualizująca zgodę w Google
    function updateConsent(isAccepted) {
        window.gtag('consent', 'update', {
            analytics_storage: isAccepted ? 'granted' : 'denied',
            ad_storage: isAccepted ? 'granted' : 'denied'
        });
        localStorage.setItem('cookie-consent', isAccepted ? 'accepted' : 'rejected');
        hideBanner();
    }

    function hideBanner() {
        banner.classList.add('translate-y-10', 'opacity-0');
        setTimeout(() => banner.classList.add('hidden'), 500);
    }

    // Sprawdź czy użytkownik już podjął decyzję
    const consent = localStorage.getItem('cookie-consent');
    if (!consent) {
        banner.classList.remove('hidden');
        setTimeout(() => banner.classList.remove('translate-y-10', 'opacity-0'), 100);
    } else if (consent === 'accepted') {
        // Jeśli wcześniej zaakceptował, odblokuj Google
        window.gtag('consent', 'update', {
            analytics_storage: 'granted',
            ad_storage: 'granted'
        });
    }

    acceptBtn.addEventListener('click', () => updateConsent(true));
    rejectBtn.addEventListener('click', () => updateConsent(false));
</script>
