---
import Analytics from '@vercel/analytics/astro'
import SpeedInsights from "@vercel/speed-insights/astro"
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
import '@fontsource/merriweather'
import '@fontsource/inter'

interface Props {
    title: string
    description?: string
    image?: string
}

const {
    title,
    description = "Gospodarstwo sadowniczo-edukacyjne Owocowa Przystań. Warsztaty dla dzieci, natura i ekologia.",
    image = "/og-image.jpg"
} = Astro.props
const siteUrl = Astro.site || 'https://owocowaprzystan.pl';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const imageUrl = new URL(image, siteUrl);
---

<!doctype html>
<html lang="pl" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <title>{title} | Owocowa Przystań</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />

        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <!--<meta property="og:image" content={imageUrl} />-->
        <meta property="og:site_name" content="Owocowa Przystań" />
        <meta property="og:locale" content="pl_PL" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:url" content={canonicalURL} />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <!--<meta name="twitter:image" content={imageUrl} />-->

        <meta name="generator" content={Astro.generator} />
    </head>
    <body class="bg-op-cream text-op-brown font-sans antialiased selection:bg-op-red selection:text-white">
        <Navbar />
        <main class="min-h-screen pt-20">
            <slot />
        </main>
        <Footer />
        <Analytics/>
        <SpeedInsights />
    </body>
</html>
